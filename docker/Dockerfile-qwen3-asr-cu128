# Dockerfile of qwenllm/qwen3-asr:cu128

ARG CUDA_VERSION=12.8.0
ARG from=nvidia/cuda:${CUDA_VERSION}-devel-ubuntu22.04
FROM ${from} as base

ARG DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get upgrade -y && apt-get install -y --no-install-recommends \
    git \
    git-lfs \
    python3 \
    python3-pip \
    python3-dev \
    wget \
    vim \
    libsndfile1 \
    ccache \
    software-properties-common \
    ffmpeg \
    ca-certificates \
 && rm -rf /var/lib/apt/lists/*

RUN wget -q https://github.com/Kitware/CMake/releases/download/v3.26.1/cmake-3.26.1-Linux-x86_64.sh \
    -O /tmp/cmake-install.sh \
    && chmod +x /tmp/cmake-install.sh \
    && mkdir -p /opt/cmake-3.26.1 \
    && /tmp/cmake-install.sh --skip-license --prefix=/opt/cmake-3.26.1 \
    && rm /tmp/cmake-install.sh \
    && ln -sf /opt/cmake-3.26.1/bin/* /usr/local/bin/

RUN ln -s /usr/bin/python3 /usr/bin/python

RUN git lfs install

WORKDIR /app

ENV MAX_JOBS=32
ENV NVCC_THREADS=2
ENV CCACHE_DIR=/root/.cache/ccache

ARG BUNDLE_FLASH_ATTENTION=true

RUN pip3 install -U pip setuptools wheel

RUN apt remove python3-blinker -y

# Copy requirements and install dependencies
COPY requirement.txt /app/requirement.txt
RUN pip3 install -U -r requirement.txt

# Flash Attention is already included in qwen-asr[vllm]
RUN if [ "$BUNDLE_FLASH_ATTENTION" = "true" ]; then \
        pip3 install -U flash-attn --no-build-isolation; \
    fi

# Cleanup
RUN rm -rf /root/.cache/pip /var/lib/apt/lists/*

# Copy qwen_asr_app.py
COPY qwen_asr_app.py /app/qwen_asr_app.py

EXPOSE 80

# Default command: run the FastAPI application
CMD ["python3", "qwen_asr_app.py"]
